<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_pms" name="Show PMS Dashboard" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">PMS Dashboard</t>
                <t t-set="url" t-value="'/my/pms'"/>
                <t t-set="placeholdertext">Manage your smart home</t>
            </t>
        </xpath>
    </template>

    <template id="portal_pms_dashboard" name="PMS Resident Dashboard">
        <t t-call="portal.portal_layout">
            <div class="pms-glass-container">
                <div class="row">
                    <div class="col-12">
                        <h2 class="mb-4 text-white">Command Center</h2>
                    </div>
                </div>

                <div class="row">
                    <!-- Telemetry Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism h-100">
                            <h4>STAPS Live Telemetry</h4>
                            <div id="pms_staps_status" class="mt-3">
                                <p>Source Node: <span class="text-info">CNS-Main-01</span></p>
                                <p>Signal Latency: <span id="staps_latency" class="h4">--</span> ms</p>
                                <p>Secure Coordinate: <small id="staps_coord" class="text-muted">--</small></p>
                            </div>
                        </div>
                    </div>

                    <!-- Happiness Coin Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism h-100">
                            <h4>Sustainability Rewards</h4>
                            <div class="coin-balance-display mt-3 text-center">
                                <span class="h1 text-warning" t-esc="request.env.user.happiness_coin_balance"/>
                                <div class="text-muted mt-2">Happiness Coins</div>
                            </div>
                            <div class="text-center mt-3">
                                <button class="btn btn-primary w-100" id="btn_claim_reward">Claim Reward (5.0)</button>
                            </div>
                        </div>
                    </div>

                    <!-- Eco Efficiency Score -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism h-100 text-center">
                            <h4>Eco-Efficiency Score</h4>
                            <div class="mt-3">
                                <h1 class="display-3 text-success" t-esc="request.env.user.eco_efficiency_score"/>
                                <p class="text-muted">Global Percentile: <t t-esc="request.env.user.eco_efficiency_score * 0.9"/>%</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Google Home Integration Token Widget -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="pms-card glass-morphism">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h4>Google Home Integration</h4>
                                    <p class="text-muted mb-0">Use this token to link your property with Google Home.</p>
                                </div>
                                <div class="text-right">
                                    <code class="h4 text-warning" t-esc="request.env.user.google_home_token or 'Not Generated'"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="pms-card glass-morphism">
                            <h4>My Smart Devices</h4>
                            <div class="table-responsive mt-3">
                                <table class="table text-white border-0">
                                    <thead>
                                        <tr class="border-bottom border-secondary">
                                            <th>Device</th>
                                            <th>Type</th>
                                            <th>Brightness / Eco</th>
                                            <th>Status</th>
                                            <th class="text-right">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="pms_device_list">
                                        <t t-foreach="request.env['pms.device'].search([('resident_id', '=', request.env.user.id)])" t-as="device">
                                            <tr class="align-middle">
                                                <td>
                                                    <div class="font-weight-bold" t-esc="device.name"/>
                                                    <small class="text-muted" t-esc="device.room_name"/>
                                                </td>
                                                <td><span class="badge badge-outline-light" t-esc="device.device_type.split('.')[-1]"/></td>
                                                <td>
                                                    <t t-if="device.device_type == 'action.devices.types.LIGHT'">
                                                        <div class="mb-2">
                                                            <small class="text-muted d-block">Brightness</small>
                                                            <input type="range" class="brightness-slider pms-brightness w-100"
                                                                   t-att-data-id="device.id" min="0" max="100" t-att-value="device.brightness"/>
                                                        </div>
                                                        <div>
                                                            <small class="text-muted d-block">Color Temp (K)</small>
                                                            <input type="range" class="color-temp-slider pms-color-temp w-100"
                                                                   t-att-data-id="device.id" min="2000" max="9000" t-att-value="device.color_temp"/>
                                                        </div>
                                                    </t>
                                                    <t t-if="device.device_type == 'action.devices.types.THERMOSTAT'">
                                                        <div>
                                                            <small class="text-muted d-block">Fan Speed</small>
                                                            <input type="range" class="fan-speed-slider pms-fan-speed w-100"
                                                                   t-att-data-id="device.id" min="0" max="100" t-att-value="device.fan_speed"/>
                                                        </div>
                                                    </t>
                                                    <t t-if="device.device_type == 'action.devices.types.SCENE'">
                                                        <div class="custom-control custom-switch">
                                                            <input type="checkbox" class="custom-control-input pms-eco-toggle"
                                                                   t-att-id="'eco_' + str(device.id)" t-att-data-id="device.id" t-att-checked="device.eco_mode"/>
                                                            <label class="custom-control-label" t-att-for="'eco_' + str(device.id)">Eco Active</label>
                                                        </div>
                                                    </t>
                                                </td>
                                                <td>
                                                    <span t-if="device.is_on" class="badge badge-success px-3 py-2">ON</span>
                                                    <span t-else="" class="badge badge-secondary px-3 py-2">OFF</span>
                                                </td>
                                                <td class="text-right">
                                                    <button class="btn btn-sm btn-outline-info pms-toggle" t-att-data-id="device.id">
                                                        <i class="fa fa-power-off mr-1"/>Toggle
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
