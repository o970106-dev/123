<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="pms_dashboard_template" name="PMS Dashboard">
        <t t-call="portal.portal_layout">
            <div class="container pms-dashboard mt-4">
                <h2>Resident Dashboard</h2>
                <div class="row">
                    <div class="col-md-4">
                        <div class="pms-widget">
                            <h4>Happiness Coins</h4>
                            <p class="display-4"><t t-esc="happiness_coins"/></p>
                            <span class="pms-telemetry-badge">CNS-SIGNAL: OK</span>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="pms-widget">
                            <h4>Smart Devices</h4>
                            <div class="list-group">
                                <t t-foreach="devices" t-as="device">
                                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                            t-att-onclick="'pmsTelemetry.toggleDevice(' + str(device.id) + ')'">
                                        <t t-esc="device.name"/>
                                        <span t-attf-class="badge badge-pill #{'badge-success' if device.is_on else 'badge-secondary'}">
                                            <t t-esc="'ON' if device.is_on else 'OFF'"/>
                                        </span>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
