<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_pms" name="Show PMS Dashboard" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">PMS Dashboard</t>
                <t t-set="url" t-value="'/my/pms'"/>
                <t t-set="placeholdertext">Manage your smart home</t>
            </t>
        </xpath>
    </template>

    <template id="portal_pms_dashboard" name="PMS Resident Dashboard">
        <t t-call="portal.portal_layout">
            <div class="pms-glass-container">
                <div class="row">
                    <div class="col-12">
                        <h2 class="mb-4 text-white">Smart Home Command Center</h2>
                    </div>
                </div>

                <div class="row">
                    <!-- Telemetry Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>STAPS 2.0 Telemetry</h4>
                            <div id="pms_staps_status" class="mt-3">
                                <p>System Node: <span class="badge badge-success">CNS-MAIN-V1</span></p>
                                <p>Signal Latency: <span id="staps_latency" class="h4">--</span> <small>ms</small></p>
                                <p class="text-truncate">Coordinate: <small id="staps_coord" class="text-info">--</small></p>
                                <div class="progress mt-2" style="height: 5px; background: rgba(255,255,255,0.1);">
                                    <div id="latency_bar" class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Happiness Coin Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>Community Economy</h4>
                            <div class="coin-balance-display mt-3 text-center">
                                <span class="h1 text-warning" t-esc="request.env.user.happiness_coin_balance"/>
                                <div class="text-muted small">Available Happiness Coins</div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <button class="btn btn-sm btn-outline-light flex-grow-1 mr-1" id="btn_claim_reward">Claim Reward</button>
                                <button class="btn btn-sm btn-outline-info flex-grow-1 ml-1">Marketplace</button>
                            </div>
                        </div>
                    </div>

                    <!-- Eco-Efficiency Score -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>Sustainability Score</h4>
                            <div class="text-center mt-3">
                                <span class="h1 text-success" t-esc="int(getattr(request.env.user, 'eco_efficiency_score', 85))"/>
                                <span class="h4 text-success">%</span>
                                <div class="text-muted small">Eco-Efficiency Rating</div>
                            </div>
                            <div class="mt-3">
                                <div class="d-flex justify-content-between small">
                                    <span>Community Rank</span>
                                    <span class="text-warning">#12 / 450</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Devices Control -->
                    <div class="col-lg-8 mb-4">
                        <div class="pms-card glass-morphism h-100">
                            <h4>My Smart Devices</h4>
                            <div class="table-responsive mt-3">
                                <table class="table text-white border-0">
                                    <thead>
                                        <tr class="border-bottom border-secondary">
                                            <th>Device</th>
                                            <th>Capability</th>
                                            <th>Status</th>
                                            <th class="text-right">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="pms_device_list">
                                        <t t-foreach="request.env['pms.device'].search([('resident_id', '=', request.env.user.id)])" t-as="device">
                                            <tr class="border-bottom border-transparent">
                                                <td>
                                                    <div class="font-weight-bold" t-esc="device.name"/>
                                                    <small class="text-muted" t-esc="device.device_type.split('.')[-1].upper()"/>
                                                </td>
                                                <td>
                                                    <t t-if="'LIGHT' in device.device_type">
                                                        <small>Brightness: <t t-esc="device.brightness"/>%</small>
                                                    </t>
                                                    <t t-elif="'THERMOSTAT' in device.device_type">
                                                        <small>Temp: <t t-esc="device.temperature"/>°C</small>
                                                    </t>
                                                    <t t-else="">
                                                        <small>Standard Control</small>
                                                    </t>
                                                </td>
                                                <td>
                                                    <span t-if="device.is_on" class="badge badge-success p-2">ACTIVE</span>
                                                    <span t-else="" class="badge badge-secondary p-2">INACTIVE</span>
                                                </td>
                                                <td class="text-right">
                                                    <div class="custom-control custom-switch">
                                                        <input type="checkbox" class="custom-control-input pms-toggle-switch" t-att-id="'switch_%s' % device.id" t-att-checked="'checked' if device.is_on else None" t-att-data-id="device.id"/>
                                                        <label class="custom-control-label" t-att-for="'switch_%s' % device.id"></label>
                                                    </div>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Sustainability Leaderboard -->
                    <div class="col-lg-4 mb-4">
                        <div class="pms-card glass-morphism h-100">
                            <h4>Community Leaderboard</h4>
                            <div class="mt-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-warning text-dark text-center mr-3" style="width: 30px; height: 30px; line-height: 30px;">1</div>
                                    <div class="flex-grow-1">Unit 1402</div>
                                    <div class="text-success font-weight-bold">98%</div>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-secondary text-white text-center mr-3" style="width: 30px; height: 30px; line-height: 30px;">2</div>
                                    <div class="flex-grow-1">Unit 0805</div>
                                    <div class="text-success font-weight-bold">96%</div>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-info text-white text-center mr-3" style="width: 30px; height: 30px; line-height: 30px;">3</div>
                                    <div class="flex-grow-1">Unit 2201</div>
                                    <div class="text-success font-weight-bold">95%</div>
                                </div>
                                <hr style="border-color: rgba(255,255,255,0.1);"/>
                                <div class="d-flex align-items-center bg-primary-transparent p-2 rounded">
                                    <div class="rounded-circle bg-light text-dark text-center mr-3" style="width: 30px; height: 30px; line-height: 30px;">12</div>
                                    <div class="flex-grow-1 font-weight-bold">Me (Unit 1204)</div>
                                    <div class="text-success font-weight-bold">85%</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
