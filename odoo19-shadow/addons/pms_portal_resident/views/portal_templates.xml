<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_pms_dashboard" name="PMS Resident Dashboard">
        <t t-call="portal.portal_layout">
            <link rel="stylesheet" href="/pms_portal_resident/static/src/css/portal_glass.css"/>
            <script type="text/javascript" src="/pms_portal_resident/static/src/js/pms_telemetry.js"></script>

            <div id="pms_portal_root" class="container mt-4">
                <div class="row">
                    <div class="col-lg-12">
                        <h2 class="mb-4">Command Center: <t t-esc="user_id.name"/></h2>
                    </div>
                </div>

                <div class="row">
                    <!-- High-Precision Telemetry Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-glass-card h-100">
                            <h5>STAPS 2.0 Telemetry</h5>
                            <div class="d-flex align-items-center mt-3">
                                <span id="latency-indicator" class="latency-indicator latency-green"></span>
                                <span class="h4 mb-0" id="staps-latency">--ms</span>
                            </div>
                            <p class="text-muted small mt-2">Signal Latency (CNS-Main)</p>
                        </div>
                    </div>

                    <!-- Happiness Coins Widget -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-glass-card h-100">
                            <h5>Happiness Coins</h5>
                            <div class="mt-3">
                                <span class="h2" id="coin-balance"><t t-esc="'%.2f' % user_id.happiness_coin_balance"/></span>
                                <span class="ms-2">COINS</span>
                            </div>
                            <button id="claim-reward" class="btn btn-outline-light btn-sm mt-3 w-100">Claim Daily Reward</button>
                        </div>
                    </div>

                    <!-- Eco-Efficiency Score -->
                    <div class="col-md-4 mb-4">
                        <div class="pms-glass-card h-100">
                            <h5>Eco-Efficiency Score</h5>
                            <div class="mt-3">
                                <span class="h3"><t t-esc="'%.1f' % user_id.eco_efficiency_score"/> / 100</span>
                            </div>
                            <div class="eco-efficiency-bar mt-3">
                                <div class="eco-progress" t-att-style="'width: %s%%' % user_id.eco_efficiency_score"></div>
                            </div>
                            <p class="text-muted small mt-2">Environmental Impact Rating</p>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-lg-12">
                        <h3>My Devices</h3>
                    </div>
                </div>

                <div class="row">
                    <t t-foreach="request.env['pms.device'].sudo().search([('resident_id', '=', request.env.user.id)])" t-as="device">
                        <div class="col-md-4 mb-4">
                            <div class="pms-glass-card">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="mb-0"><t t-esc="device.name"/></h6>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input device-toggle" type="checkbox"
                                               t-att-checked="device.is_on" t-att-data-device-id="device.id"/>
                                    </div>
                                </div>

                                <t t-if="device.device_type == 'action.devices.types.LIGHT'">
                                    <div class="mt-3">
                                        <label class="small text-muted d-block">Brightness</label>
                                        <input type="range" class="form-range brightness-slider" min="0" max="100"
                                               t-att-value="device.brightness" t-att-data-device-id="device.id"/>
                                    </div>
                                </t>

                                <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-2">
                                    <span class="small text-muted"><t t-esc="device.room_name"/></span>
                                    <button class="btn btn-sm eco-toggle"
                                            t-att-class="'btn-primary' if device.eco_mode else 'btn-outline-primary'"
                                            t-att-data-device-id="device.id">
                                        Eco Mode
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
