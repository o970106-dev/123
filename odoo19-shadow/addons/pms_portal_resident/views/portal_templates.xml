<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_pms" name="Show PMS Dashboard" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">PMS Dashboard</t>
                <t t-set="url" t-value="'/my/pms'"/>
                <t t-set="placeholdertext">Manage your smart home</t>
            </t>
        </xpath>
    </template>

    <template id="portal_pms_dashboard" name="PMS Resident Dashboard">
        <t t-call="portal.portal_layout">
            <div class="pms-glass-container">
                <div class="row">
                    <div class="col-12">
                        <h2 class="mb-4 text-white">Smart Home Dashboard</h2>
                    </div>
                </div>

                <div class="row">
                    <!-- Telemetry Widget -->
                    <div class="col-md-6 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>Real-time Telemetry</h4>
                            <div id="pms_staps_status" class="mt-3">
                                <p>STAPS Node: <span class="badge badge-success">Active</span></p>
                                <p>Last Latency: <span id="staps_latency">--</span> ms</p>
                                <p>Coordinate: <span id="staps_coord">--</span></p>
                            </div>
                        </div>
                    </div>

                    <!-- Happiness Coin Widget -->
                    <div class="col-md-6 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>Happiness Coins</h4>
                            <div class="coin-balance-display mt-3">
                                <span class="h1 text-warning" t-esc="request.env.user.happiness_coin_balance"/>
                                <span class="ml-2">Coins</span>
                            </div>
                            <button class="btn btn-outline-light mt-3" id="btn_claim_reward">Claim Energy Reward</button>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Sustainability Analytics -->
                    <div class="col-12 mb-4">
                        <div class="pms-card glass-morphism">
                            <h4>Sustainability Analytics</h4>
                            <div class="row mt-3">
                                <div class="col-md-4 text-center border-right border-secondary">
                                    <h5 class="text-muted">Weekly Efficiency</h5>
                                    <h3 class="text-success">98.2%</h3>
                                </div>
                                <div class="col-md-4 text-center border-right border-secondary">
                                    <h5 class="text-muted">Carbon Saved</h5>
                                    <h3 class="text-info">12.5 kg</h3>
                                </div>
                                <div class="col-md-4 text-center">
                                    <h5 class="text-muted">Global Rank</h5>
                                    <h3 class="text-warning">#42</h3>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h6>Recent Transactions</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm text-white">
                                        <tbody>
                                            <t t-foreach="request.env['pms.happiness.coin'].search([('user_id', '=', request.env.user.id)], limit=5)" t-as="coin">
                                                <tr>
                                                    <td><t t-esc="coin.date" t-options='{"widget": "datetime"}'/></td>
                                                    <td t-esc="coin.reason"/>
                                                    <td class="text-right">
                                                        <span t-attf-class="badge #{'badge-success' if coin.amount > 0 else 'badge-danger'}">
                                                            <t t-esc="'+' if coin.amount > 0 else ''"/><t t-esc="coin.amount"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="pms-card glass-morphism">
                            <h4>My Devices</h4>
                            <div class="table-responsive mt-3">
                                <table class="table text-white">
                                    <thead>
                                        <tr>
                                            <th>Device</th>
                                            <th>Type</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="pms_device_list">
                                        <t t-foreach="request.env['pms.device'].search([('resident_id', '=', request.env.user.id)])" t-as="device">
                                            <tr>
                                                <td t-esc="device.name"/>
                                                <td t-esc="device.device_type"/>
                                                <td>
                                                    <span t-if="device.is_on" class="badge badge-success">ON</span>
                                                    <span t-else="" class="badge badge-secondary">OFF</span>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-primary pms-toggle" t-att-data-id="device.id">Toggle</button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
