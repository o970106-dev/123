<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_pms" name="Portal My Home : PMS Entry" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t_call="portal.portal_docs_entry">
                <t t_set="title">Property Management (STAPS)</t>
                <t t_set="url" t_value="'/my/pms'"/>
                <t t_set="placeholdertext">Manage your smart home at O(1) speed</t>
            </t>
        </xpath>
    </template>

    <template id="pms_portal_home" name="PMS Portal Home">
        <t t_call="portal.portal_layout">
            <style>
                .glass-card {
                    background: rgba(255, 255, 255, 0.15);
                    border-radius: 20px;
                    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
                    backdrop-filter: blur(12px);
                    -webkit-backdrop-filter: blur(12px);
                    border: 1px solid rgba(255, 255, 255, 0.18);
                    transition: transform 0.3s ease;
                }
                .glass-card:hover {
                    transform: translateY(-5px);
                }
                .staps-pulse {
                    color: #00ff00;
                    text-shadow: 0 0 15px #00ff00;
                    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                    font-weight: bold;
                }
                .telemetry-node {
                    font-size: 0.7rem;
                    color: rgba(255,255,255,0.6);
                }
            </style>
            <div id="pms_portal_content" class="container py-4">
                <div class="row mb-4">
                    <div class="col-12 d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="mb-0">Welcome, <t t_esc="resident_name"/></h2>
                            <p class="text-muted">Double J Neural Adapter PF-Node Active</p>
                        </div>
                        <div class="glass-card p-3 text-center" style="min-width: 180px;">
                            <small class="text-uppercase font-weight-bold text-white-50">STAPS Engineering Speed</small>
                            <div class="h4 staps-pulse mb-0" id="staps_speed_val"><t t_esc="engineering_speed"/> ms</div>
                            <div class="telemetry-node">CNS -> PF NODE (O1)</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-4">
                        <div class="card glass-card text-white bg-primary">
                            <div class="card-body">
                                <h6>Happiness Coins</h6>
                                <div class="h3"><t t_esc="happiness_coins"/> 🪙</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="card glass-card bg-info text-white">
                            <div class="card-body">
                                <h6>Sustainability Hub</h6>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" id="energySaveToggle" t_att-checked="energy_save_active" data-on-label="Eco On" data-off-label="Eco Off"/>
                                    <label class="form-check-label" for="energySaveToggle">Eco Mode (Reward +5🪙)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="card glass-card">
                            <div class="card-body">
                                <h6>Management Fee</h6>
                                <span class="badge bg-success">Paid</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="card glass-card">
                            <div class="card-body">
                                <h6>Active Tasks</h6>
                                <div class="h4">2</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-8">
                        <h4>Smart Devices</h4>
                        <div class="row" t_if="smart_devices">
                            <t t_foreach="smart_devices" t_as="device">
                                <div class="col-md-6 mb-3">
                                    <div class="card glass-card shadow-sm">
                                        <div class="card-body d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-0"><t t_esc="device.name"/></h6>
                                                <small class="text-muted"><t t_esc="device.room_name or 'Unit'"/></small>
                                            </div>
                                            <div class="text-right">
                                                <div class="btn-group btn-group-sm mb-2">
                                                    <button type="button" class="btn btn-outline-primary device-toggle-btn" t_att-data-device-id="device.id">
                                                        <i class="fa fa-power-off"></i> Toggle
                                                    </button>
                                                </div>
                                                <br/>
                                                <span t_attf-class="badge #{device.state_on and 'bg-warning text-dark' or 'bg-secondary'} device-status-badge">
                                                    <t t_esc="device.state_on and 'ON' or 'OFF'"/>
                                                </span>
                                                <div class="mt-1 small text-muted">Last Sync: <t t_esc="device.last_sync_timestamp"/></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="alert alert-light glass-card" t_if="not smart_devices">
                            No smart devices detected in this unit.
                        </div>
                    </div>
                    <div class="col-md-4">
                        <h4>System Latency (Theoretical)</h4>
                        <div class="card glass-card">
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush bg-transparent">
                                    <li class="list-group-item bg-transparent d-flex justify-content-between">
                                        <span>CNS Broadcast</span>
                                        <span class="text-success">0.0007 ms</span>
                                    </li>
                                    <li class="list-group-item bg-transparent d-flex justify-content-between">
                                        <span>Edge Processing</span>
                                        <span class="text-success">0.0120 ms</span>
                                    </li>
                                    <li class="list-group-item bg-transparent d-flex justify-content-between font-weight-bold">
                                        <span>Target STAPS</span>
                                        <span class="text-primary">0.0127 ms</span>
                                    </li>
                                </ul>
                            </div>
                            <div class="card-footer small text-muted">
                                * Latency values are STAPS O(1) architectural targets.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
