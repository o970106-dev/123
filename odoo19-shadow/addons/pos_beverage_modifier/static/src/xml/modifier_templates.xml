<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <templates xml:space="preserve">
    <t t-name="pos_beverage_modifier.ModifierDialog">
      <div class="bm-dialog" role="dialog" aria-modal="true" aria-labelledby="modifierDialogTitle">
        <h2 id="modifierDialogTitle" tabindex="0">設定飲品選項</h2>

        <div class="bm-tabs" role="tablist">
          <button class="bm-tab" role="tab" aria-selected="true" t-on-click="() => state.tab='sweetness'">糖分</button>
          <button class="bm-tab" role="tab" aria-selected="false" t-on-click="() => state.tab='size'">尺寸</button>
          <button class="bm-tab" role="tab" aria-selected="false" t-on-click="() => state.tab='temperature'">溫度</button>
        </div>

        <div class="bm-panels">
          <div t-if="state.tab==='sweetness'" class="bm-panel" role="radiogroup" aria-labelledby="labelSweetness">
            <label id="labelSweetness" class="bm-label">選擇糖分</label>
            <button class="bm-radio" t-on-click="() => onPick('sweetness','正常糖 (100%)')">正常糖 (100%)</button>
            <button class="bm-radio" t-on-click="() => onPick('sweetness','少糖 (70%)')">少糖 (70%)</button>
            <button class="bm-radio" t-on-click="() => onPick('sweetness','半糖 (50%)')">半糖 (50%)</button>
            <button class="bm-radio" t-on-click="() => onPick('sweetness','微糖 (30%)')">微糖 (30%)</button>
            <button class="bm-radio" t-on-click="() => onPick('sweetness','更換蔗糖')">更換蔗糖 (+5)</button>
          </div>

          <div t-if="state.tab==='size'" class="bm-panel" role="radiogroup" aria-labelledby="labelSize">
            <label id="labelSize" class="bm-label">選擇尺寸</label>
            <button class="bm-radio" t-on-click="() => onPick('size','大杯 (600cc)')">大杯 (600cc) (+30)</button>
            <button class="bm-radio" t-on-click="() => onPick('size','中杯 (450cc)')">中杯 (450cc)</button>
            <button class="bm-radio" t-on-click="() => onPick('size','小杯 (350cc)')">小杯 (350cc) (-15)</button>
          </div>

          <div t-if="state.tab==='temperature'" class="bm-panel" role="radiogroup" aria-labelledby="labelTemperature">
            <label id="labelTemperature" class="bm-label">選擇溫度</label>
            <button class="bm-radio" t-on-click="() => onPick('temperature','熱飲')">熱飲</button>
            <button class="bm-radio" t-on-click="() => onPick('temperature','溫飲')">溫飲</button>
            <button class="bm-radio" t-on-click="() => onPick('temperature','去冰')">去冰</button>
            <button class="bm-radio" t-on-click="() => onPick('temperature','微冰')">微冰</button>
            <button class="bm-radio" t-on-click="() => onPick('temperature','正常冰')">正常冰</button>
            <button class="bm-radio" t-on-click="() => onPick('temperature','冰沙')">冰沙 (+10)</button>
          </div>
        </div>

        <div class="bm-actions">
          <button class="bm-reset" t-on-click="onReset">重置</button>
          <button class="bm-confirm" t-att-disabled="!state.canConfirm" t-on-click="onConfirm">確認</button>
        </div>
      </div>
    </t>
  </templates>
</odoo>

