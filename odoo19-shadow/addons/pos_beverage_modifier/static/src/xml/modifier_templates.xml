<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <templates xml:space="preserve">
    <t t-name="pos_beverage_modifier.ModifierDialog">
      <div class="bm-dialog" role="dialog" aria-modal="true" aria-labelledby="modifierDialogTitle" t-on-mousedown="onInteract">
        <h2 id="modifierDialogTitle" tabindex="0">
            <t t-esc="props.product.display_name"/> - 設定選項
        </h2>

        <div class="bm-tabs" role="tablist">
          <button t-if="sweetnessLines.length" class="bm-tab" t-att-class="{'active': state.tab === 'sweetness'}" role="tab" t-on-click="() => state.tab='sweetness'">糖分</button>
          <button t-if="sizeLines.length" class="bm-tab" t-att-class="{'active': state.tab === 'size'}" role="tab" t-on-click="() => state.tab='size'">尺寸</button>
          <button t-if="temperatureLines.length" class="bm-tab" t-att-class="{'active': state.tab === 'temperature'}" role="tab" t-on-click="() => state.tab='temperature'">溫度</button>
        </div>

        <div class="bm-panels">
          <div t-if="state.tab==='sweetness' &amp;&amp; sweetnessLines.length" class="bm-panel" role="radiogroup" aria-labelledby="labelSweetness">
            <label id="labelSweetness" class="bm-label">選擇糖分</label>
            <t t-foreach="sweetnessLines" t-as="line" t-key="line.id">
                <button class="bm-radio" t-att-class="{'selected': state.sweetness &amp;&amp; state.sweetness.id === line.id}" t-on-click="() => onPick('sweetness', line)">
                    <t t-esc="line.name"/>
                    <t t-if="line.price > 0"> (+<t t-esc="line.price"/>)</t>
                    <t t-if="line.price &lt; 0"> (<t t-esc="line.price"/>)</t>
                </button>
            </t>
          </div>

          <div t-if="state.tab==='size' &amp;&amp; sizeLines.length" class="bm-panel" role="radiogroup" aria-labelledby="labelSize">
            <label id="labelSize" class="bm-label">選擇尺寸</label>
            <t t-foreach="sizeLines" t-as="line" t-key="line.id">
                <button class="bm-radio" t-att-class="{'selected': state.size &amp;&amp; state.size.id === line.id}" t-on-click="() => onPick('size', line)">
                    <t t-esc="line.name"/>
                    <t t-if="line.price > 0"> (+<t t-esc="line.price"/>)</t>
                    <t t-if="line.price &lt; 0"> (<t t-esc="line.price"/>)</t>
                </button>
            </t>
          </div>

          <div t-if="state.tab==='temperature' &amp;&amp; temperatureLines.length" class="bm-panel" role="radiogroup" aria-labelledby="labelTemperature">
            <label id="labelTemperature" class="bm-label">選擇溫度</label>
            <t t-foreach="temperatureLines" t-as="line" t-key="line.id">
                <button class="bm-radio" t-att-class="{'selected': state.temperature &amp;&amp; state.temperature.id === line.id}" t-on-click="() => onPick('temperature', line)">
                    <t t-esc="line.name"/>
                    <t t-if="line.price > 0"> (+<t t-esc="line.price"/>)</t>
                    <t t-if="line.price &lt; 0"> (<t t-esc="line.price"/>)</t>
                </button>
            </t>
          </div>
        </div>

        <div class="bm-actions">
          <button class="bm-reset" t-on-click="onReset">重置</button>
          <button class="bm-confirm" t-att-disabled="!state.canConfirm" t-on-click="onConfirm">確認</button>
        </div>
      </div>
    </t>
  </templates>
</odoo>
