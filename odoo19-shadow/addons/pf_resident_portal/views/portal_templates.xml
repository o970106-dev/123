<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_pms" name="Portal My Home : PMS Entry" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t_call="portal.portal_docs_entry">
                <t t_set="title">Property Management</t>
                <t t_set="url" t_value="'/my/pms'"/>
                <t t_set="placeholdertext">Manage your property and smart home</t>
            </t>
        </xpath>
    </template>

    <template id="pms_portal_home" name="PMS Portal Home">
        <t t_call="portal.portal_layout">
            <t t_set="breadcrumbs_searchbar" t_value="True"/>
            <div id="pms_portal_content">
                <div class="container">
                    <div class="row mt-4">
                        <div class="col-12">
                            <h3>Welcome, <t t_esc="resident_name"/></h3>
                            <p class="text-muted">Your Unified Property Management Dashboard</p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card bg-primary text-white mb-4">
                                <div class="card-body">
                                    <h5 class="card-title">Management Fee</h5>
                                    <p class="card-text">Status: <t t_esc="management_fee_status"/></p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-success text-white mb-4">
                                <div class="card-body">
                                    <h5 class="card-title">Facility Reservations</h5>
                                    <p class="card-text">Active: <t t_esc="active_reservations"/></p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-warning text-dark mb-4">
                                <div class="card-body">
                                    <h5 class="card-title">Announcements</h5>
                                    <p class="card-text">Unread: <t t_esc="unread_announcements"/></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-md-8">
                            <h4>Smart Home Quick Control</h4>
                            <div class="row" t_if="smart_devices">
                                <t t_foreach="smart_devices" t_as="device">
                                    <div class="col-md-6 mb-3">
                                        <div class="card shadow-sm">
                                            <div class="card-body d-flex justify-content-between align-items-center">
                                                <div>
                                                    <h6 class="mb-0"><t t_esc="device.name"/></h6>
                                                    <small class="text-muted"><t t_esc="device.room_name or 'Main Room'"/></small>
                                                </div>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" t_att-checked="device.state_on" id="flexSwitchCheckDefault"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="alert alert-info" t_if="not smart_devices">
                                No smart devices found. Integration with Google Home is active.
                            </div>
                        </div>
                        <div class="col-md-4">
                            <h4>Energy Summary</h4>
                            <div class="card border-warning mb-3">
                                <div class="card-header bg-warning text-dark">Today's Usage</div>
                                <div class="card-body text-center">
                                    <h2 class="card-title text-warning"><t t_esc="energy_data['today_usage']"/></h2>
                                    <p class="card-text text-muted">Status: <span class="badge bg-success"><t t_esc="energy_data['status']"/></span></p>
                                </div>
                                <div class="card-footer bg-transparent">
                                    Forecast: <t t_esc="energy_data['monthly_forecast']"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
