<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Resident Device Isolation: Can only see/edit their own devices -->
        <record id="pms_device_resident_rule" model="ir.rule">
            <field name="name">PMS Device: Resident Isolation</field>
            <field name="model_id" ref="model_pms_device"/>
            <field name="groups" eval="[(4, ref('portal.group_portal')), (4, ref('base.group_user'))]"/>
            <field name="domain_force">[('resident_id', '=', user.id)]</field>
        </record>

        <!-- Resident Telemetry Isolation: Can only see their own telemetry if applicable -->
        <!-- Note: Telemetry currently doesn't have a direct link to resident_id,
             so we default to allowing internal users (managers) to see all,
             and restrict portal users to empty if we don't have a lookup.
             For highest degree, we would link telemetry to user. -->
    </data>
</odoo>
