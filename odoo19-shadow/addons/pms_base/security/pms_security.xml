<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="pms_device_resident_rule" model="ir.rule">
            <field name="name">Resident: Own Devices Only</field>
            <field name="model_id" ref="model_pms_device"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('resident_id', '=', user.id)]</field>
        </record>

        <record id="pms_telemetry_resident_rule" model="ir.rule">
            <field name="name">Resident: Own Telemetry Only</field>
            <field name="model_id" ref="model_pms_telemetry"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
        </record>
    </data>
</odoo>
