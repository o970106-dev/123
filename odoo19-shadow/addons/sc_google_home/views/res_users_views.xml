<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_google_home" model="ir.ui.view">
        <field name="name">res.users.form.google.home</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Google Home" name="google_home">
                    <group>
                        <field name="google_home_token"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
