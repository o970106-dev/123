<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_google_home_device_tree" model="ir.ui.view">
        <name>sc.google.home.device.tree</name>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_type"/>
                <field name="state_on"/>
            </list>
        </field>
    </record>

    <record id="view_sc_google_home_device_form" model="ir.ui.view">
        <name>sc.google.home.device.form</name>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="device_type"/>
                        <field name="traits"/>
                    </group>
                    <group string="State">
                        <field name="state_on"/>
                        <field name="brightness" invisible="not 'Brightness' in traits"/>
                        <field name="color_temp" invisible="not 'ColorSetting' in traits"/>
                        <field name="target_temp" invisible="not 'TemperatureSetting' in traits"/>
                        <field name="fan_speed" invisible="not 'FanSpeed' in traits"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_google_home_device" model="ir.actions.act_window">
        <name>Google Home Devices</name>
        <field name="res_model">sc.google.home.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_smart_control_root" name="Smart Control" sequence="100"/>
    <menuitem id="menu_sc_google_home_device" name="Devices" parent="menu_smart_control_root" action="action_sc_google_home_device"/>
</odoo>
