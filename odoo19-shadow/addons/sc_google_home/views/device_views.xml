<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_google_home_device_tree" model="ir.ui.view">
        <field name="name">sc.google.home.device.tree</field>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <tree string="Google Home Devices">
                <field name="name"/>
                <field name="device_type"/>
                <field name="state_on"/>
                <field name="brightness"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_google_home_device_form" model="ir.ui.view">
        <field name="name">sc.google.home.device.form</field>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <form string="Google Home Device">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="device_type"/>
                            <field name="traits"/>
                        </group>
                        <group>
                            <field name="state_on"/>
                            <field name="brightness"/>
                            <field name="color_temp"/>
                            <field name="target_temp"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_google_home_device" model="ir.actions.act_window">
        <field name="name">Google Home Devices</field>
        <field name="res_model">sc.google.home.device</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_smart_control_root" name="Smart Control" sequence="10"/>
    <menuitem id="menu_sc_google_home_device" name="Devices" parent="menu_smart_control_root" action="action_sc_google_home_device"/>
</odoo>
