<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_google_home_device_tree" model="ir.ui.view">
        <field name="name">sc.google.home.device.tree</field>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_type"/>
                <field name="state_on"/>
                <field name="brightness"/>
            </list>
        </field>
    </record>

    <record id="view_sc_google_home_device_form" model="ir.ui.view">
        <field name="name">sc.google.home.device.form</field>
        <field name="model">sc.google.home.device</field>
        <field name="arch" type="xml">
            <form>
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Device Name (e.g. Living Room Light)"/>
                        </h1>
                    </div>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="device_type"/>
                            <field name="traits"/>
                        </group>
                        <group name="states" string="Device States">
                            <field name="state_on"/>
                            <field name="brightness" invisible="'action.devices.traits.Brightness' not in traits"/>
                            <field name="color_temp" invisible="'action.devices.traits.ColorSetting' not in traits"/>
                            <field name="target_temp" invisible="'action.devices.traits.TemperatureSetting' not in traits"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_google_home_device" model="ir.actions.act_window">
        <field name="name">Google Home Devices</field>
        <field name="res_model">sc.google.home.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sc_google_home_root" name="Smart Control" sequence="10"/>
    <menuitem id="menu_sc_google_home_device" name="Google Home Devices" parent="menu_sc_google_home_root" action="action_sc_google_home_device" sequence="10"/>
</odoo>
