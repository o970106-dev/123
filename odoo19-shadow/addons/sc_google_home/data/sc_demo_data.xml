<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="device_living_room_light" model="sc.google.home.device">
            <field name="name">Living Room Light</field>
            <field name="device_type">action.devices.types.LIGHT</field>
            <field name="traits">action.devices.traits.OnOff,action.devices.traits.Brightness,action.devices.traits.ColorSetting</field>
            <field name="state_on">True</field>
            <field name="brightness">80</field>
            <field name="color_temp">2700</field>
        </record>

        <record id="device_bedroom_ac" model="sc.google.home.device">
            <field name="name">Bedroom AC</field>
            <field name="device_type">action.devices.types.THERMOSTAT</field>
            <field name="traits">action.devices.traits.TemperatureSetting</field>
            <field name="target_temp">24.0</field>
        </record>

        <!-- Google Home Bearer Token Example -->
        <record id="config_parameter_google_home_token" model="ir.config_parameter">
            <field name="key">sc_google_home.bearer_token</field>
            <field name="value">pms_authority_secure_token_2026</field>
        </record>
    </data>
</odoo>
