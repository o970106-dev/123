<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smart_device_tree" model="ir.ui.view">
        <field name="name">smart.device.tree</field>
        <field name="model">smart.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_type"/>
                <field name="state"/>
                <field name="room_id"/>
            </list>
        </field>
    </record>

    <record id="view_smart_device_form" model="ir.ui.view">
        <field name="name">smart.device.form</field>
        <field name="model">smart.device</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="device_id"/>
                        <field name="device_type"/>
                        <field name="state"/>
                        <field name="brightness" invisible="device_type != 'action.devices.types.LIGHT'"/>
                        <field name="room_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smart_device" model="ir.actions.act_window">
        <field name="name">Smart Devices</field>
        <field name="res_model">smart.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_smart_home_root" name="Smart Home"/>
    <menuitem id="menu_smart_device" name="Devices" parent="menu_smart_home_root" action="action_smart_device"/>
</odoo>
