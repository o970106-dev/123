<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <templates xml:space="preserve">
        <t t-name="pos_beverage_modifier.ModifierDialog">
            <div class="bm-dialog shadow-lg" role="dialog" aria-modal="true" aria-labelledby="modifierDialogTitle">
                <div class="bm-header">
                    <h2 id="modifierDialogTitle" tabindex="0">
                        <i class="fa fa-coffee mr-2"/>設定飲品選項
                    </h2>
                    <div class="bm-branding">
                        <small>五常小J 竭誠為您服務</small>
                    </div>
                </div>

                <div class="bm-tabs" role="tablist">
                    <button t-attf-class="bm-tab #{state.tab === 'sweetness' ? 'active' : ''}"
                            role="tab" t-att-aria-selected="state.tab === 'sweetness'"
                            t-on-click="() => state.tab='sweetness'">
                        <i class="fa fa-tint mr-1"/>糖分
                    </button>
                    <button t-attf-class="bm-tab #{state.tab === 'size' ? 'active' : ''}"
                            role="tab" t-att-aria-selected="state.tab === 'size'"
                            t-on-click="() => state.tab='size'">
                        <i class="fa fa-arrows-v mr-1"/>尺寸
                    </button>
                    <button t-attf-class="bm-tab #{state.tab === 'temperature' ? 'active' : ''}"
                            role="tab" t-att-aria-selected="state.tab === 'temperature'"
                            t-on-click="() => state.tab='temperature'">
                        <i class="fa fa-thermometer-half mr-1"/>溫度
                    </button>
                </div>

                <div class="bm-panels mt-3">
                    <div t-if="state.tab==='sweetness'" class="bm-panel" role="radiogroup" aria-labelledby="labelSweetness">
                        <label id="labelSweetness" class="bm-label">選擇糖分 (甜度)</label>
                        <div class="bm-grid">
                            <t t-foreach="['正常糖 (100%)', '少糖 (70%)', '半糖 (50%)', '微糖 (30%)', '更換蔗糖']" t-as="opt" t-key="opt">
                                <button t-attf-class="bm-radio #{state.sweetness === opt ? 'selected' : ''}"
                                        t-on-click="() => onPick('sweetness', opt)">
                                    <t t-esc="opt"/>
                                    <t t-if="opt === '更換蔗糖'"><span class="bm-extra">+5</span></t>
                                    <i t-if="state.sweetness === opt" class="fa fa-check-circle ml-auto text-primary"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <div t-if="state.tab==='size'" class="bm-panel" role="radiogroup" aria-labelledby="labelSize">
                        <label id="labelSize" class="bm-label">選擇飲品尺寸</label>
                        <div class="bm-grid">
                            <t t-foreach="[['大杯 (600cc)', '+30'], ['中杯 (450cc)', ''], ['小杯 (350cc)', '-15']]" t-as="opt" t-key="opt[0]">
                                <button t-attf-class="bm-radio #{state.size === opt[0] ? 'selected' : ''}"
                                        t-on-click="() => onPick('size', opt[0])">
                                    <t t-esc="opt[0]"/>
                                    <t t-if="opt[1]"><span t-attf-class="bm-extra #{opt[1].startsWith('-') ? 'text-success' : ''}"><t t-esc="opt[1]"/></span></t>
                                    <i t-if="state.size === opt[0]" class="fa fa-check-circle ml-auto text-primary"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <div t-if="state.tab==='temperature'" class="bm-panel" role="radiogroup" aria-labelledby="labelTemperature">
                        <label id="labelTemperature" class="bm-label">選擇溫度/冰量</label>
                        <div class="bm-grid">
                            <t t-foreach="['熱飲', '溫飲', '去冰', '微冰', '正常冰', '冰沙']" t-as="opt" t-key="opt">
                                <button t-attf-class="bm-radio #{state.temperature === opt ? 'selected' : ''}"
                                        t-on-click="() => onPick('temperature', opt)">
                                    <t t-esc="opt"/>
                                    <t t-if="opt === '冰沙'"><span class="bm-extra">+10</span></t>
                                    <i t-if="state.temperature === opt" class="fa fa-check-circle ml-auto text-primary"/>
                                </button>
                            </t>
                        </div>
                    </div>
                </div>

                <div class="bm-actions border-top pt-3 mt-auto">
                    <button class="bm-btn bm-reset btn btn-outline-secondary" t-on-click="onReset">
                        <i class="fa fa-refresh mr-1"/>重置
                    </button>
                    <button t-attf-class="bm-btn bm-confirm btn #{state.canConfirm ? 'btn-primary' : 'btn-secondary'}"
                            t-att-disabled="!state.canConfirm" t-on-click="onConfirm">
                        <i class="fa fa-check mr-1"/>確認加入
                    </button>
                </div>
            </div>
        </t>
    </templates>
</odoo>
