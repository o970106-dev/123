<odoo>
    <record id="view_pm3_base_config_tree" model="ir.ui.view">
        <field name="name">pm3.base.config.tree</field>
        <field name="model">pm3.base.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="system_code"/>
                <field name="governance_mode"/>
                <field name="m5_policy_enabled"/>
                <field name="audit_fabric_enabled"/>
            </tree>
        </field>
    </record>

    <record id="view_pm3_base_config_form" model="ir.ui.view">
        <field name="name">pm3.base.config.form</field>
        <field name="model">pm3.base.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="system_code"/>
                        <field name="governance_mode"/>
                    </group>
                    <group>
                        <field name="m5_policy_enabled"/>
                        <field name="audit_fabric_enabled"/>
                        <field name="ai_runtime_enabled"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_pm3_base_config" model="ir.actions.act_window">
        <field name="name">PM3 Base Config</field>
        <field name="res_model">pm3.base.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_pm3_base_config"
              name="PM3 Base Config"
              parent="pm3_base.menu_pm3_config"
              action="action_pm3_base_config"
              sequence="10"/>
</odoo>
