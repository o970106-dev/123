<odoo>
    <record id="view_pm3_identity_tree" model="ir.ui.view">
        <field name="name">pm3.identity.tree</field>
        <field name="model">pm3.identity</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="sid"/>
                <field name="identity_type"/>
                <field name="state"/>
                <field name="trust_level"/>
            </tree>
        </field>
    </record>

    <record id="view_pm3_identity_form" model="ir.ui.view">
        <field name="name">pm3.identity.form</field>
        <field name="model">pm3.identity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sid"/>
                        <field name="identity_type"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="partner_id"/>
                        <field name="user_id"/>
                        <field name="trust_level"/>
                    </group>
                    <group string="Identity Foundation">
                        <field name="line_user_id"/>
                        <field name="google_user_id"/>
                        <button name="action_link_line" string="Link LINE" type="object" class="oe_highlight"/>
                        <button name="action_link_google" string="Link Google" type="object" class="oe_highlight"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_pm3_identity" model="ir.actions.act_window">
        <field name="name">PM3 Identities</field>
        <field name="res_model">pm3.identity</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_pm3_identity"
              name="Identities"
              parent="pm3_base.menu_pm3_root"
              action="action_pm3_identity"
              sequence="30"/>
</odoo>
